{
  "name": "revealjs-editor",
  "version": "1.0.0",
  "private": true,
  "description": "A WYSIWYG presentation editor powered by reveal.js",
  "author": {
    "name": "jbirky",
    "email": "jbirky@users.noreply.github.com"
  },
  "main": "electron/main.js",
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=server\" \"npm run dev --workspace=client\"",
    "build": "npm run build --workspace=client",
    "start": "NODE_ENV=production npm run start --workspace=server",
    "electron:dev": "npm run build && electron .",
    "electron:prepare": "npm run build && node scripts/prepare-electron.js",
    "electron:build": "npm run electron:prepare && npx electron-builder",
    "electron:build:linux": "npm run electron:prepare && npx electron-builder --linux",
    "electron:build:mac": "npm run electron:prepare && npx electron-builder --mac",
    "electron:build:win": "npm run electron:prepare && npx electron-builder --win"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8"
  }
}
