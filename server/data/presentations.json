            "content": "<p><span style=\"font-family: &quot;Computer Modern Sans&quot;, sans-serif;\">computer modern</span></p><p><span style=\"font-family: &quot;Computer Modern Serif&quot;, serif;\">computer modern</span></p><p><span style=\"font-family: &quot;Latin Modern Roman&quot;, serif;\">latin modern</span></p>"
