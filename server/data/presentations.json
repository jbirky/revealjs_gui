      {
        "id": "7ac70041-5af7-432a-8b86-e286727a1417",
        "elements": [
          {
            "id": "f632c1a9-daa0-4eaa-bb3e-3a6fd7d3d94b",
            "type": "html",
            "x": 80,
            "y": 80,
            "width": 500,
            "height": 380,
            "zIndex": 2,
            "content": "  <script src=\"https://cdn.jsdelivr.net/npm/d3@7\"></script>\n  <style>\n    * { box-sizing: border-box; margin: 0; }\n    body { background: transparent; overflow: hidden; }\n    .node circle { stroke: rgba(255,255,255,0.3); stroke-width: 1.5; cursor: grab; }\n    .node circle:active { cursor: grabbing; }\n    .node text { fill: white; font: 12px sans-serif; pointer-events: none; text-shadow: 0 1px 4px rgba(0,0,0,0.8); }\n    .link { stroke: rgba(255,255,255,0.15); stroke-width: 1.5; }\n    .tooltip { position: fixed; background: rgba(0,0,0,0.75); color: white; padding: 6px 10px; border-radius: 6px; font: 13px\n   sans-serif; pointer-events: none; opacity: 0; transition: opacity 0.15s; }\n  </style>\n\n  <svg id=\"viz\"></svg>\n  <div class=\"tooltip\" id=\"tip\"></div>\n\n  <script>\n  const W = window.innerWidth, H = window.innerHeight;\n  const svg = d3.select('#viz').attr('width', W).attr('height', H);\n  const tip = document.getElementById('tip');\n\n  const nodes = [\n    {id:'ML',     r:28, color:'#6366f1'},\n    {id:'Neural\\nNets', r:22, color:'#8b5cf6'},\n    {id:'CNN',    r:18, color:'#a78bfa'},\n    {id:'RNN',    r:18, color:'#a78bfa'},\n    {id:'Transformers',r:22,color:'#7c3aed'},\n    {id:'NLP',    r:20, color:'#06b6d4'},\n    {id:'Vision', r:20, color:'#0891b2'},\n    {id:'Data',   r:22, color:'#10b981'},\n    {id:'Stats',  r:18, color:'#34d399'},\n    {id:'Python', r:20, color:'#f59e0b'},\n    {id:'PyTorch',r:18, color:'#fb923c'},\n    {id:'TF',     r:18, color:'#ef4444'},\n  ];\n\n  const links = [\n    {source:'ML',target:'Neural\\nNets'},{source:'ML',target:'Data'},\n    {source:'ML',target:'Stats'},{source:'Neural\\nNets',target:'CNN'},\n    {source:'Neural\\nNets',target:'RNN'},{source:'Neural\\nNets',target:'Transformers'},\n    {source:'Transformers',target:'NLP'},{source:'CNN',target:'Vision'},\n    {source:'ML',target:'Python'},{source:'Python',target:'PyTorch'},\n    {source:'Python',target:'TF'},{source:'PyTorch',target:'Neural\\nNets'},\n    {source:'TF',target:'Neural\\nNets'},{source:'NLP',target:'Transformers'},\n    {source:'Data',target:'Python'},{source:'Stats',target:'Data'},\n  ];\n\n  const g = svg.append('g');\n\n  svg.call(d3.zoom().scaleExtent([0.4,3]).on('zoom', e => g.attr('transform', e.transform)));\n\n  const sim = d3.forceSimulation(nodes)\n    .force('link', d3.forceLink(links).id(d=>d.id).distance(90).strength(0.6))\n    .force('charge', d3.forceManyBody().strength(-300))\n    .force('center', d3.forceCenter(W/2, H/2))\n    .force('collision', d3.forceCollide(d => d.r + 10));\n\n  const link = g.selectAll('.link').data(links).join('line').attr('class','link');\n\n  const node = g.selectAll('.node').data(nodes).join('g').attr('class','node')\n    .call(d3.drag()\n      .on('start', (e,d) => { if(!e.active) sim.alphaTarget(0.3).restart(); d.fx=d.x; d.fy=d.y; })\n      .on('drag',  (e,d) => { d.fx=e.x; d.fy=e.y; })\n      .on('end',   (e,d) => { if(!e.active) sim.alphaTarget(0); d.fx=null; d.fy=null; }))\n    .on('mouseover', (e,d) => { tip.style.opacity=1; tip.textContent=d.id.replace('\\n',' '); })\n    .on('mousemove', e  => { tip.style.left=(e.clientX+12)+'px'; tip.style.top=(e.clientY-28)+'px'; })\n    .on('mouseout',  ()  => { tip.style.opacity=0; });\n\n  node.append('circle').attr('r', d=>d.r).attr('fill', d=>d.color);\n  node.append('text').attr('text-anchor','middle').attr('dy','0.35em')\n    .style('font-size', d => Math.max(9, d.r*0.55)+'px')\n    .selectAll('tspan').data(d => d.id.split('\\n')).join('tspan')\n      .attr('x',0).attr('dy',(d,i,a) => i===0 && a.length>1 ? '-0.5em' : i>0 ? '1.1em' : 0)\n      .text(d=>d);\n\n  sim.on('tick', () => {\n    link.attr('x1',d=>d.source.x).attr('y1',d=>d.source.y)\n        .attr('x2',d=>d.target.x).attr('y2',d=>d.target.y);\n    node.attr('transform', d=>`translate(${d.x},${d.y})`);\n  });\n  </script>\n"
          }
        ],
