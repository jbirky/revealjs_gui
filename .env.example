# Parallax — Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Mode ─────────────────────────────────────────────────────
# "selfhosted" = single-user, file storage, no auth (default)
# "cloud" = multi-tenant, Postgres, auth, billing
PARALLAX_MODE=selfhosted

# ── Database ─────────────────────────────────────────────────
# "file" = JSON files on disk (default, used in selfhosted mode)
# "postgres" = PostgreSQL (required for cloud mode)
PARALLAX_DB=file
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/parallax?sslmode=require

# ── Authentication (Clerk) ───────────────────────────────────
# Get these from https://dashboard.clerk.com → your app → API Keys
CLERK_PUBLISHABLE_KEY=pk_test_xxxx
CLERK_SECRET_KEY=sk_test_xxxx

# ── Billing (Stripe) ────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
# Use test keys (sk_test_ / pk_test_) during development
STRIPE_SECRET_KEY=sk_test_xxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxx
# Webhook signing secret — from Stripe Dashboard → Webhooks → your endpoint
STRIPE_WEBHOOK_SECRET=whsec_xxxx

# ── File Storage (Cloudflare R2) ─────────────────────────────
# "local" = local filesystem (default, used in selfhosted mode)
# "r2" = Cloudflare R2 (S3-compatible, used in cloud mode)
PARALLAX_STORAGE=local
R2_ENDPOINT=https://xxxx.r2.cloudflarestorage.com
R2_ACCESS_KEY=xxxx
R2_SECRET_KEY=xxxx
R2_BUCKET=parallax-uploads

# ── Email (Resend) ──────────────────────────────────────────
# Optional — for transactional email (welcome, receipts)
# Get from https://resend.com/api-keys
RESEND_API_KEY=re_xxxx

# ── Frontend (Vite) ─────────────────────────────────────────
# These are exposed to the browser — only put public keys here
VITE_PARALLAX_MODE=selfhosted
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxx

# ── Server ──────────────────────────────────────────────────
PORT=3002
NODE_ENV=development
# Public URL for absolute asset links (used in GitHub export)
PARALLAX_PUBLIC_URL=https://parallax-presentations.com
