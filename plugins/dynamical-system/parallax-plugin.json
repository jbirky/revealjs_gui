{
  "id": "com.parallax.dynamical-system",
  "name": "Dynamical System",
  "version": "1.0.0",
  "parallaxEngine": ">=1.0.0",
  "author": {
    "name": "Parallax",
    "url": "https://parallax-presentations.com"
  },
  "license": "AGPL-3.0",
  "description": "Interactive 2D dynamical system — phase portraits, time series, vector fields, trajectories, nullclines, and fixed points.",
  "main": "./plugin.js",
  "sandbox": "./sandbox.html",
  "contributes": {
    "elementTypes": [
      {
        "type": "dynamical-system",
        "label": "Dynamical System",
        "defaultSize": { "width": 600, "height": 500 },
        "defaultData": {
          "dxdt": "y",
          "dydt": "-sin(x) - 0.3*y",
          "xMin": -8,
          "xMax": 8,
          "yMin": -5,
          "yMax": 5,
          "gridDensity": 18,
          "trajectories": [
            { "x": 1, "y": 0 },
            { "x": -3, "y": 2 },
            { "x": 5, "y": -1 }
          ],
          "showField": true,
          "showNullclines": false,
          "showFixedPoints": true,
          "fieldColor": "rgba(100,160,255,0.35)",
          "bgColor": "#0f0f1a",
          "dt": 0.03,
          "maxSteps": 2000,
          "tMax": 30
        },
        "toolbar": {
          "menu": "embed",
          "position": "after:html"
        }
      }
    ],
    "exportHooks": [
      {
        "id": "dynamical-system-static",
        "formats": ["html"],
        "description": "Renders dynamical system as static snapshot"
      }
    ]
  },
  "permissions": []
}
