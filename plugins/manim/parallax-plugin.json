{
  "id": "com.parallax.manim",
  "name": "Manim Animations",
  "version": "1.0.0",
  "parallaxEngine": ">=1.0.0",
  "author": {
    "name": "Parallax",
    "url": "https://parallax-presentations.com"
  },
  "license": "AGPL-3.0",
  "description": "Create mathematical animations with Manim — write Python code, render to video, embed on slides.",
  "main": "./plugin.js",
  "sandbox": "./sandbox.html",
  "contributes": {
    "elementTypes": [
      {
        "type": "manim",
        "label": "Manim Animation",
        "defaultSize": { "width": 480, "height": 360 },
        "defaultData": {
          "content": "",
          "sceneName": "MyScene",
          "quality": "l",
          "rendered": null,
          "controls": false,
          "autoplay": true,
          "loop": true,
          "muted": true
        },
        "toolbar": {
          "menu": "plugins"
        }
      }
    ],
    "exportHooks": [
      {
        "id": "manim-video-export",
        "formats": ["html"],
        "description": "Embeds rendered Manim video in export"
      }
    ]
  },
  "permissions": []
}
